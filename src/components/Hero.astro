---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * Hero Component
 *
 * @description A component that displays a hero section with a title, description, and image
 */
interface Props {
  /**
   * The source URL for the image
   */
  src?: string
}

const { src = '/moon-3.jpg' }: Props = Astro.props
---

<section class="hero relative isolate overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-no-repeat"
    style={`background-image: url('${src}'); background-position: center 60%;`}
    aria-hidden="true"
  ></div>
  <div class="container relative z-10 flex min-h-[calc(75svh+100px)] items-center py-20 md:py-28">
    <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <h1 class="text-center text-6xl md:text-left lg:text-8xl">
          <slot><span class="text-gradient ">Ziva Wernick</span> </slot>
        </h1>
        <h2 class="max-w-2xl text-pretty text-3xl font-large text-white/92 md:text-4xl outlined-text">
          Software Developer Building Tech for Social Impact
        </h2>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <Link
            href="https://github.com/ziva-wernick/radiant-zivawernick"
            isButton
            type="primary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:star" size="1.5rem" />
            Follow Ziva on GitHub
          </Link>
          <Link
            href="/contact"
            isButton
            type="secondary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:mail" size="1.5rem" />
            Contact Ziva
          </Link>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }
  .outlined-text {
    /* More saturated colors (500 range) for better contrast against white text and moon */
    --stroke-color: light-dark(var(--color-primary-500), var(--color-secondary-500));
    -webkit-text-stroke: 2px var(--stroke-color);
    
    /* Strong core shadow for legibility + brand glow for aesthetic */
    text-shadow: 
      0 4px 12px rgba(0, 0, 0, 0.9),
      0 0 20px light-dark(rgba(214, 72, 255, 0.4), rgba(0, 209, 183, 0.4));
      
    paint-order: stroke fill;
  }
  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
