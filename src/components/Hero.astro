---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * Hero Component
 *
 * @description A component that displays a hero section with a title, description, and image
 */
interface Props {
  /**
   * The source URL for the image
   */
  src?: string
}

const { src = '/watermarked-moon.jpg' }: Props = Astro.props
---

<section class="hero relative isolate overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-no-repeat"
    style={`background-image: url('${src}'); background-position: center 60%;`}
    aria-hidden="true"
  ></div>
  <div class="container relative z-10 flex min-h-[calc(75svh+100px)] items-center py-20 md:py-28">
    <div class="flex max-w-3xl flex-col items-center gap-8 text-center md:items-start md:text-left">
      <h1 class="text-6xl text-white md:text-7xl lg:text-8xl">
        <slot><span class="text-gradient">Ziva Wernick</span> </slot>
      </h1>
      <h2 class="max-w-2xl text-pretty text-xl font-medium text-white/92 md:text-2xl">
        Software Developer Building Tech for Social Impact
      </h2>
      <div class="flex flex-col gap-3 min-[500px]:flex-row">
        <Link
          href="https://github.com/ziva-wernick/radiant-zivawernick"
          isButton
          type="primary"
          animateOnHover
          animationType="boop"
        >
          <Icon aria-hidden="true" name="lucide:star" size="1.5rem" />
          Follow me on GitHub
        </Link>
        <Link
          href="/contact"
          isButton
          type="secondary"
          animateOnHover
          animationType="boop"
        >
          <Icon aria-hidden="true" name="lucide:bookmark" size="1.5rem" />
          Contact Ziva
        </Link>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .text-gradient {
    background: linear-gradient(
      315deg,
      rgb(255 255 255 / 1) 20%,
      rgb(221 233 255 / 0.82) 100%
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 24px rgb(255 255 255 / 0.1);
  }
</style>
