<dialog id="gallery-lightbox" class="lightbox backdrop:bg-black/90 backdrop:backdrop-blur-sm">
  <div class="lightbox-wrapper">
    <form method="dialog">
      <button class="close-button" aria-label="Close lightbox">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </form>
    
    <button class="nav-button prev" aria-label="Previous gallery item" id="lightbox-prev">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>

    <div class="lightbox-content">
      <div class="image-container">
        <div class="loader"></div>
        <img id="lightbox-image" src="" alt="" />
        <video id="lightbox-video" controls playsinline preload="metadata" hidden>
          <source id="lightbox-video-source" src="" type="video/mp4" />
        </video>
      </div>
      <div class="lightbox-info">
        <p id="lightbox-caption"></p>
        <span id="lightbox-counter" class="text-sm text-gray-400"></span>
      </div>
    </div>

    <button class="nav-button next" aria-label="Next gallery item" id="lightbox-next">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</dialog>

<script>
  let currentIndex = 0
  let currentGalleryButtons: Element[] = []
  let currentMediaType = 'image'
  let touchStartX = 0

  const getElements = () => {
    const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement | null
    const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement | null
    const lightboxVideo = document.getElementById('lightbox-video') as HTMLVideoElement | null
    const lightboxVideoSource = document.getElementById('lightbox-video-source') as HTMLSourceElement | null
    const lightboxCaption = document.getElementById('lightbox-caption')
    const lightboxCounter = document.getElementById('lightbox-counter')
    const prevBtn = document.getElementById('lightbox-prev')
    const nextBtn = document.getElementById('lightbox-next')
    const loader = document.querySelector('.loader')

    return {
      dialog,
      lightboxImg,
      lightboxVideo,
      lightboxVideoSource,
      lightboxCaption,
      lightboxCounter,
      prevBtn,
      nextBtn,
      loader,
    }
  }

  const stopVideoPlayback = () => {
    const { lightboxVideo, lightboxVideoSource } = getElements()
    if (!lightboxVideo || !lightboxVideoSource) return

    lightboxVideo.pause()
    lightboxVideo.removeAttribute('poster')
    lightboxVideoSource.src = ''
    lightboxVideo.load()
  }

  const updateLightbox = (index: number) => {
    const button = currentGalleryButtons[index] as HTMLElement | undefined
    const {
      lightboxImg,
      lightboxVideo,
      lightboxVideoSource,
      lightboxCaption,
      lightboxCounter,
      loader,
    } = getElements()

    if (!button || !lightboxImg || !lightboxVideo || !lightboxVideoSource || !lightboxCaption || !lightboxCounter) return

    const mediaType = button.dataset.mediaType ?? 'image'
    const src = button.dataset.mediaSrc
    const alt = button.dataset.mediaAlt ?? ''
    const poster = button.dataset.mediaPoster
    const lightboxFit = button.dataset.lightboxFit ?? 'contain'
    const lightboxPosition = button.dataset.lightboxPosition ?? 'center center'

    if (!src) return

    currentMediaType = mediaType

    if (loader) loader.classList.toggle('visible', mediaType === 'image')

    lightboxCaption.textContent = alt
    lightboxCounter.textContent = `${index + 1} / ${currentGalleryButtons.length}`
    currentIndex = index

    lightboxImg.style.objectFit = lightboxFit
    lightboxImg.style.objectPosition = lightboxPosition
    lightboxVideo.style.objectFit = lightboxFit
    lightboxVideo.style.objectPosition = lightboxPosition

    if (mediaType === 'video') {
      lightboxImg.hidden = true
      lightboxImg.style.opacity = '0'
      lightboxImg.removeAttribute('src')

      lightboxVideo.hidden = false
      if (poster) lightboxVideo.poster = poster
      // Change the source type here when extending lightbox video support beyond MP4.
      lightboxVideoSource.src = src
      lightboxVideo.load()

      if (loader) loader.classList.remove('visible')
      void lightboxVideo.play().catch(() => {
        // Autoplay can be blocked by browser policy; controls remain available.
      })
      return
    }

    stopVideoPlayback()
    lightboxVideo.hidden = true
    lightboxImg.hidden = false
    lightboxImg.style.opacity = '0'
    lightboxImg.src = src
    lightboxImg.alt = alt
  }

  const showNext = () => {
    if (currentGalleryButtons.length <= 1) return
    updateLightbox((currentIndex + 1) % currentGalleryButtons.length)
  }

  const showPrev = () => {
    if (currentGalleryButtons.length <= 1) return
    updateLightbox((currentIndex - 1 + currentGalleryButtons.length) % currentGalleryButtons.length)
  }

  const setupGallery = () => {
    const { dialog, lightboxImg, prevBtn, nextBtn } = getElements()
    const buttons = document.querySelectorAll('.gallery-item')

    if (!dialog || !lightboxImg || !prevBtn || !nextBtn) return

    lightboxImg.onload = () => {
      const { loader } = getElements()
      if (loader) loader.classList.remove('visible')
      lightboxImg.style.opacity = '1'
    }

    buttons.forEach(button => {
      button.onclick = () => {
        const container = button.closest('.gallery-container')
        if (!container) return
        
        currentGalleryButtons = Array.from(container.querySelectorAll('.gallery-item'))
        const index = currentGalleryButtons.indexOf(button)
        
        updateLightbox(index)
        dialog.showModal()
        document.body.style.overflow = 'hidden'
      }
    })

    // Assign click handlers directly to avoid duplicate listeners on persistent elements
    nextBtn.onclick = (e) => { e.stopPropagation(); showNext() }
    prevBtn.onclick = (e) => { e.stopPropagation(); showPrev() }

    dialog.onclose = () => {
      currentMediaType = 'image'
      stopVideoPlayback()
      document.body.style.overflow = ''
    }

    dialog.onclick = (e) => {
      if (e.target === dialog) dialog.close()
    }

    // Use a single window listener that checks if the dialog is open
    if (!(window as any).galleryInited) {
      window.addEventListener('keydown', (e) => {
        const activeDialog = document.getElementById('gallery-lightbox') as HTMLDialogElement
        if (!activeDialog || !activeDialog.open) return

        if (currentMediaType === 'video' && (e.key === 'ArrowRight' || e.key === 'ArrowLeft')) return
        if (e.key === 'ArrowRight') showNext()
        if (e.key === 'ArrowLeft') showPrev()
        if (e.key === 'Escape') activeDialog.close()
      })
      
      // Touch support
      window.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX
      }, { passive: true })
      
      window.addEventListener('touchend', (e) => {
        const touchEndX = e.changedTouches[0].screenX
        const activeDialog = document.getElementById('gallery-lightbox') as HTMLDialogElement
        if (!activeDialog || !activeDialog.open) return
        if (currentMediaType === 'video') return
        
        if (touchStartX - touchEndX > 50) showNext()
        if (touchEndX - touchStartX > 50) showPrev()
      }, { passive: true })

      ;(window as any).galleryInited = true
    }
  }

  // Initial setup
  setupGallery()
  // Re-run on Astro navigation
  document.addEventListener('astro:after-swap', setupGallery)
</script>

<style lang="scss" is:global>
  .lightbox {
    padding: 0;
    border: none;
    background: transparent;
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    
    &::backdrop {
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(8px);
    }

    .lightbox-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 100%;
      padding: 1rem;
      
      @media (min-width: 768px) {
        padding: 4rem;
      }
    }

    .close-button {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(0, 0, 0, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      color: white;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 70;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;

      &:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
      }
    }

    .nav-button {
      display: none; // Hidden on small mobile
      background: rgba(0, 0, 0, 0.3);
      border: none;
      color: white;
      cursor: pointer;
      padding: 1rem;
      z-index: 60;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      border-radius: 50%;
      position: absolute;

      @media (min-width: 768px) {
        display: flex;
      }

      &:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: scale(1.1);
      }

      &.prev { left: 1rem; }
      &.next { right: 1rem; }
    }

    .lightbox-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 90vw;
      max-height: 85vh;

      .image-container {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: min(75vh, calc(100vh - 12rem));
        overflow: hidden;
      }

      .loader {
        position: absolute;
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top: 3px solid white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
        
        &.visible {
          opacity: 1;
        }
      }

      img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center center;
        border-radius: 4px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        transition: opacity 0.3s ease;
      }

      video {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center center;
        border-radius: 4px;
        background: black;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      }

      [hidden] {
        display: none !important;
      }

      .lightbox-info {
        margin-top: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        background: rgba(0, 0, 0, 0.6);
        padding: 0.75rem 2rem;
        border-radius: 9999px;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        p {
          color: white;
          font-size: 1rem;
          margin: 0;
        }
      }
    }
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>
