<dialog id="gallery-lightbox" class="lightbox backdrop:bg-black/90 backdrop:backdrop-blur-sm">
  <div class="lightbox-wrapper">
    <form method="dialog">
      <button class="close-button" aria-label="Close lightbox">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </form>
    
    <button class="nav-button prev" aria-label="Previous image" id="lightbox-prev">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>

    <div class="lightbox-content">
      <div class="image-container">
        <div class="loader"></div>
        <img id="lightbox-image" src="" alt="" />
      </div>
      <div class="lightbox-info">
        <p id="lightbox-caption"></p>
        <span id="lightbox-counter" class="text-sm text-gray-400"></span>
      </div>
    </div>

    <button class="nav-button next" aria-label="Next image" id="lightbox-next">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</dialog>

<script>
  let currentIndex = 0
  let currentGalleryButtons: Element[] = []

  const setupGallery = () => {
    const dialog = document.getElementById('gallery-lightbox') as HTMLDialogElement
    const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement
    const lightboxCaption = document.getElementById('lightbox-caption')
    const lightboxCounter = document.getElementById('lightbox-counter')
    const buttons = document.querySelectorAll('.gallery-item')
    const prevBtn = document.getElementById('lightbox-prev')
    const nextBtn = document.getElementById('lightbox-next')
    const loader = document.querySelector('.loader')

    if (!dialog || !lightboxImg || !lightboxCaption || !prevBtn || !nextBtn || !lightboxCounter) return

    const updateLightbox = (index: number) => {
      const button = currentGalleryButtons[index]
      if (!button) return

      const src = button.getAttribute('data-image-src')
      const alt = button.getAttribute('data-image-alt')
      
      if (src) {
        if (loader) loader.classList.add('visible')
        lightboxImg.style.opacity = '0'
        
        lightboxImg.src = src
        lightboxImg.alt = alt || ''
        if (lightboxCaption) lightboxCaption.textContent = alt || ''
        if (lightboxCounter) lightboxCounter.textContent = `${index + 1} / ${currentGalleryButtons.length}`
        currentIndex = index
      }
    }

    lightboxImg.onload = () => {
      if (loader) loader.classList.remove('visible')
      lightboxImg.style.opacity = '1'
    }

    const showNext = () => {
      if (currentGalleryButtons.length <= 1) return
      const nextIndex = (currentIndex + 1) % currentGalleryButtons.length
      updateLightbox(nextIndex)
    }

    const showPrev = () => {
      if (currentGalleryButtons.length <= 1) return
      const prevIndex = (currentIndex - 1 + currentGalleryButtons.length) % currentGalleryButtons.length
      updateLightbox(prevIndex)
    }

    // Use event delegation or re-attach to fresh buttons
    buttons.forEach(button => {
      button.onclick = () => {
        const container = button.closest('.gallery-container')
        if (!container) return
        
        currentGalleryButtons = Array.from(container.querySelectorAll('.gallery-item'))
        const index = currentGalleryButtons.indexOf(button)
        
        updateLightbox(index)
        dialog.showModal()
        document.body.style.overflow = 'hidden'
      }
    })

    // Assign click handlers directly to avoid duplicate listeners on persistent elements
    nextBtn.onclick = (e) => { e.stopPropagation(); showNext() }
    prevBtn.onclick = (e) => { e.stopPropagation(); showPrev() }

    dialog.onclose = () => {
      document.body.style.overflow = ''
    }

    dialog.onclick = (e) => {
      if (e.target === dialog) dialog.close()
    }

    // Use a single window listener that checks if the dialog is open
    if (!(window as any).galleryInited) {
      window.addEventListener('keydown', (e) => {
        const activeDialog = document.getElementById('gallery-lightbox') as HTMLDialogElement
        if (!activeDialog || !activeDialog.open) return

        if (e.key === 'ArrowRight') showNext()
        if (e.key === 'ArrowLeft') showPrev()
        if (e.key === 'Escape') activeDialog.close()
      })
      
      // Touch support
      let touchStartX = 0
      let touchEndX = 0
      
      window.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX
      }, { passive: true })
      
      window.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX
        const activeDialog = document.getElementById('gallery-lightbox') as HTMLDialogElement
        if (!activeDialog || !activeDialog.open) return
        
        if (touchStartX - touchEndX > 50) showNext()
        if (touchEndX - touchStartX > 50) showPrev()
      }, { passive: true })

      ;(window as any).galleryInited = true
    }
  }

  // Initial setup
  setupGallery()
  // Re-run on Astro navigation
  document.addEventListener('astro:after-swap', setupGallery)
</script>

<style lang="scss" is:global>
  .lightbox {
    padding: 0;
    border: none;
    background: transparent;
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    
    &::backdrop {
      background: rgba(0, 0, 0, 0.9);
      backdrop-filter: blur(8px);
    }

    .lightbox-wrapper {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 100%;
      padding: 1rem;
      
      @media (min-width: 768px) {
        padding: 4rem;
      }
    }

    .close-button {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: rgba(0, 0, 0, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      color: white;
      cursor: pointer;
      padding: 0.5rem;
      z-index: 70;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;

      &:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
      }
    }

    .nav-button {
      display: none; // Hidden on small mobile
      background: rgba(0, 0, 0, 0.3);
      border: none;
      color: white;
      cursor: pointer;
      padding: 1rem;
      z-index: 60;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      border-radius: 50%;
      position: absolute;

      @media (min-width: 768px) {
        display: flex;
      }

      &:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: scale(1.1);
      }

      &.prev { left: 1rem; }
      &.next { right: 1rem; }
    }

    .lightbox-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 90vw;
      max-height: 85vh;

      .image-container {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      .loader {
        position: absolute;
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top: 3px solid white;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
        
        &.visible {
          opacity: 1;
        }
      }

      img {
        max-width: 100%;
        max-height: 75vh;
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        transition: opacity 0.3s ease;
      }

      .lightbox-info {
        margin-top: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        background: rgba(0, 0, 0, 0.6);
        padding: 0.75rem 2rem;
        border-radius: 9999px;
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        p {
          color: white;
          font-size: 1rem;
          margin: 0;
        }
      }
    }
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>
